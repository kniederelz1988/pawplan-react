{
    "compilerOptions": {
        "target": "es2020",
        "lib": ["es2020", "DOM"],

        "module": "esnext",

        "outDir": "./dist",
        "rootDir": "./src",
        "sourceMap": true,

        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,

        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,

        "jsx": "preserve",

        "paths": {
            "@hooks/*": ["./src/hooks/*"],
            "@components/*": ["./src/components/*"],
            "@contexts/*": ["./contexts/*"],
            "@fb/*": ["./src/firebase/*"],
            "@models/*": ["./src/models/*"],
            "@repos/*": ["./src/repositories/*"]
        }
    },

    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}